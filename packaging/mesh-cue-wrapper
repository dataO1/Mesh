#!/bin/sh
# Wrapper for mesh-cue — sets optimal GPU rendering defaults
# Vulkan backend with Fifo (avoids surface-timeout freezes seen with Mailbox/auto_vsync
# on certain GPU/driver combos during fullscreen transitions)
# Embedded builds override via kiosk.nix where hardware is known
# These can be overridden by setting the env vars before launching
export WGPU_BACKEND="${WGPU_BACKEND:-vulkan}"
export ICED_PRESENT_MODE="${ICED_PRESENT_MODE:-fifo}"
exec /usr/lib/mesh/mesh-cue "$@"
